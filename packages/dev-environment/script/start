#!/usr/bin/env bash

set -e

DIR=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
ROOT_DIR=$DIR/../../..

MAIN_ENV_FILE=$ROOT_DIR/.env
LOCAL_ENV_FILE=$HOME/.gu/service_catalogue/.env.local
clear='\033[0m'
cyan='\033[0;36m'
yellow="\033[1;33m"
STEP_COUNT=0

# Build a reusable docker compose command using layered env files.
# The repo .env provides shared defaults, and the optional user-local
# .env.local can override only the keys that differ for a given machine
# or runtime setup. Docker Compose processes these env files in order.
COMPOSE_CMD=(docker compose -f "${DIR}/../docker-compose.yaml" --env-file "$MAIN_ENV_FILE")
if [[ -f "$LOCAL_ENV_FILE" ]]; then
  COMPOSE_CMD+=(--env-file "$LOCAL_ENV_FILE")
fi
step() {
  # ((STEP_COUNT++)) does return 0 for some bash versions and in combination with set -e,
  # it can cause the script to exit with an error depending on the dev environment.
  STEP_COUNT=$((STEP_COUNT+1))
  echo -e "\n${cyan}Step ${STEP_COUNT}${clear}: $1"
}

ensure_container_runtime() {
  step "Checking container runtime"

  until docker info >/dev/null 2>&1; do
    echo -e "${yellow}Docker daemon is not available.${clear}"
    echo -e "${yellow}If you use an alternative runtime (for example podman/minikube) aliased to 'docker', start it now.${clear}"
    echo "Standing by for container runtime to start..."
    echo ""
    sleep 5
  done
}

ensure_prisma_available() {
  step "Checking Prisma CLI"

  if ! npm --prefix "$ROOT_DIR/packages/common" exec prisma -- --version >/dev/null 2>&1; then
    echo "Prisma is not installed for packages/common."
    echo "Run 'npm install' in the repository root first."
    exit 1
  fi
}

start_postgres() {
  step "Launching postgres"
  "${COMPOSE_CMD[@]}" up -d --build postgres

  local postgres_container
  postgres_container=$("${COMPOSE_CMD[@]}" ps -q postgres)

  if [[ -z "$postgres_container" ]]; then
    echo "Postgres container was not created."
    exit 1
  fi

  until [[ "$(docker inspect -f '{{.State.Health.Status}}' "$postgres_container" 2>/dev/null || true)" == "healthy" ]]; do
    echo "Waiting for postgres to become healthy..."
    sleep 2
  done
}

seed_database() {
  step "Running Prisma migrations and seeding database"

  set -a
  source "$MAIN_ENV_FILE"
  if [[ -f "$LOCAL_ENV_FILE" ]]; then
    source "$LOCAL_ENV_FILE"
  fi
  set +a

  (
    cd "$ROOT_DIR/packages/common"

    export DATABASE_HOSTNAME=127.0.0.1
    export DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@127.0.0.1:${DATABASE_PORT}/${DATABASE_NAME}?sslmode=disable"
    export STAGE=DEV

    npm exec prisma -- migrate deploy
    npm exec prisma -- generate
    npm exec prisma -- db seed
  )
}

start_app_containers() {
  step "Launching CloudQuery and Grafana"
  "${COMPOSE_CMD[@]}" up -d --build cloudquery grafana
}

main() {
  ensure_container_runtime
  ensure_prisma_available
  start_postgres
  seed_database
  start_app_containers
}

main